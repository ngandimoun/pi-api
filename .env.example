# -----------------------------------------------------------------------------
# Pi API — environment variable NAMES only (no secrets in repo).
# Values come from your secret store / deployment platform.
# -----------------------------------------------------------------------------

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pi CLI (local developer tooling)
PI_CLI_BASE_URL=http://localhost:3000
# Optional: canonical public base URL for deep links (used by `pi trace` / server-side link hints)
PI_APP_BASE_URL=http://localhost:3000
# Optional: remote routine templates merged into GET /api/cli/templates (JSON array of RoutineTemplate)
PI_CLI_TEMPLATE_REGISTRY_JSON=
# Optional: admin header x-pi-templates-admin must match to POST /api/cli/templates
PI_TEMPLATES_ADMIN_SECRET=
# Lite tier: intent/NLP/learn/prompt/validate fallbacks (default gemini-3.1-flash-lite-preview)
PI_CLI_GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Pro tier: routine generate/upgrade (default gemini-3.1-pro-preview)
PI_CLI_GEMINI_PRO_MODEL=gemini-3.1-pro-preview
PI_CLI_GITHUB_WEBHOOK_SECRET=

# Mastra (CLI workflows + agents; requires Postgres for workflows/memory — see PI_CLI_DATABASE_URL)
PI_MASTRA_DEFAULT_MODEL=google/gemini-3.1-pro-preview-customtools
PI_CLI_DATABASE_URL=
PI_CLI_USE_WORKFLOWS=false
PI_CLI_ROUTINE_HITL=false
PI_CLI_ENABLE_MEMORY=true
PI_CLI_MEMORY_RECALL_LIMIT=5
PI_CLI_DEVELOPER_ID=

# -----------------------------------------------------------------------------
# Pi CLI Hokage — PRODUCTION profile (set these on Vercel → piii → Production)
# -----------------------------------------------------------------------------
# PI_MASTRA_DEFAULT_MODEL=google/gemini-3.1-pro-preview-customtools
# PI_CLI_USE_WORKFLOWS=true
# PI_CLI_ROUTINE_HITL=true
# PI_CLI_ENABLE_MEMORY=true
#
# Postgres for Mastra workflow snapshots, HITL suspend/resume, and memory.
# Use the Supabase transaction pooler (port 6543) and append ?schema=mastra so
# Mastra tables stay isolated from app tables. One-time SQL in the project:
#   create schema if not exists mastra;
#   create extension if not exists vector;
#   grant all privileges on schema mastra to postgres, service_role;
# PI_CLI_DATABASE_URL=postgres://postgres.<project-ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=mastra
#
# Vercel paste checklist (PI_CLI_DATABASE_URL):
# - Value only: no "export PI_CLI_DATABASE_URL=", no wrapping quotes, no trailing newline in the field.
# - Password: if it contains @ : / ? # [ ] % — percent-encode those characters in the URI userinfo.
# - Supabase pooler: use port 6543 and add ?sslmode=require if not already present (transaction pooler).
# - After saving env vars, redeploy. Use GET /api/cli/health → checks.postgres.diagnostics.flags to see which check failed.
#
# If health shows Postgres unreachable with "self-signed certificate in certificate chain":
# - Prefer fixing the connection (correct Supabase pooler host, no TLS-intercepting proxy).
# - Last resort (insecure): PI_CLI_DATABASE_SSL_REJECT_UNAUTHORIZED=false — passes ssl.rejectUnauthorized=false to pg.
#
# Fail-closed strict mode: when ON, validate/learn/routine/resonate return
# 503 workflow_unavailable / workflow_disabled instead of silently falling back
# to legacy Gemini when a Mastra workflow is requested but fails. Per-request
# override is X-Pi-Fail-Closed: false or ?strict=false.
# PI_CLI_FAIL_CLOSED=true
# Pi CLI production safeguards (optional)
# PI_CLI_STREAMING_THRESHOLD=200
# PI_CLI_CHUNK_SIZE=50
# PI_CLI_WATCH_DEBOUNCE_MS=2000
# PI_CLI_VALIDATE_CACHE_TTL_MS=3600000
# PI_CLI_DISABLE_VALIDATE_CACHE=true
# PI_CLI_MAX_API_CALLS_PER_HOUR=100
# PI_CLI_MAX_API_CALLS_PER_HOUR_HARD=500
# PI_CLI_FORCE_VALIDATE=true
# PI_CLI_GOVERNANCE_MODE=disabled
# PI_CLI_REQUIRE_APPROVAL_FOR_MUTATIONS=true
# CLI-only: set on your machine so `pi` sends ?async=true (Trigger.dev runner) for learn/validate/routine
# PI_CLI_ASYNC=true
# Optional: Upstash Redis REST for Pi validate L3 cache (same as UPSTASH_* if already set)
PI_CLI_UPSTASH_REDIS_REST_URL=
PI_CLI_UPSTASH_REDIS_REST_TOKEN=
# Optional: dedicated bucket for Pi CLI graphs (defaults to R2_BUCKET_NAME)
R2_PI_GRAPHS_BUCKET=

# Unkey (API keys + verification; rate limits / metering)
UNKEY_ROOT_KEY=
UNKEY_API_ID=

# Supabase (Postgres + Auth + pgvector)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (metered billing; tie to Unkey identity in application logic)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Trigger.dev (durable jobs / workers)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Firecrawl (web extraction / branding capture)
FIRECRAWL_API_KEY=
FIRECRAWL_ENABLE_SCREENSHOT=true
FIRECRAWL_ENABLE_ACTION_WAIT=false
FIRECRAWL_ACTION_WAIT_MS=0

# Model providers — use DB routing in production; these are bootstrap fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Optional: default model IDs (prefer DB config)
OPENAI_DEFAULT_MODEL=
ANTHROPIC_DEFAULT_MODEL=
GOOGLE_DEFAULT_MODEL=
DEEPSEEK_DEFAULT_MODEL=
GOOGLE_BRAND_VISION_MODEL=
GOOGLE_BRAND_STRUCTURING_MODEL=gemini-3.1-pro-preview
GOOGLE_BRAND_THINKING_LEVEL=medium
GOOGLE_BRAND_VISION_MAX_OUTPUT_TOKENS=1200
GOOGLE_BRAND_STRUCTURING_MAX_OUTPUT_TOKENS=700
GOOGLE_BRAND_PROJECTION_MODEL=gemini-2.5-flash-lite
GOOGLE_BRAND_PROJECTION_MAX_OUTPUT_TOKENS=180
GOOGLE_BRAND_PROJECTION_MAX_USE_CASE_CHARS=700
GOOGLE_BRAND_PROJECTION_MODEL_USE_CASE_CHARS=220
GOOGLE_BRAND_PROJECTION_MAX_DNA_CHARS=6000
GOOGLE_BRAND_PROJECTION_MAX_BODY_BYTES=8192
GOOGLE_BRAND_PROJECTION_ABUSE_WINDOW_MS=600000
GOOGLE_BRAND_PROJECTION_ABUSE_MAX_VIOLATIONS=3

# Avatar generation (orchestrator text model; image pipeline uses separate internal config)
GOOGLE_AVATAR_ORCHESTRATOR_MODEL=
GOOGLE_ADS_ORCHESTRATOR_MODEL=
GOOGLE_CAMPAIGN_ORCHESTRATOR_MODEL=
GOOGLE_CAMPAIGN_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Scripts / golden checks (optional; see docs/v1/intro.mdx Deploy Checklist)
PI_BASE_URL=http://localhost:3000
PROJECTION_GOLDEN_BRAND_ID=
PROJECTION_GOLDEN_ORG_ID=
PROJECTION_GOLDEN_MAX_DETERMINISTIC_RATE=0
PROJECTION_GOLDEN_MAX_NON_LLM_RATE=
PROJECTION_GOLDEN_MAX_FALLBACK_RATE=
PROJECTION_GOLDEN_MAX_P95_MS=15000

# Cloudflare R2 (S3-compatible, zero egress on R2; keys only in env / secret store)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for objects (custom domain or r2.dev public bucket URL)
R2_PUBLIC_URL=


# LiveKit (voice sessions — server mints room + participant tokens; webhook optional)
# Use https://project.livekit.cloud or wss:// — server SDK is normalized to https; clients get wss.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_API_KEY=
LIVEKIT_WEBHOOK_API_SECRET=

# Voice session structured extraction uses GOOGLE_CAMPAIGN_ORCHESTRATOR_MODEL (or GOOGLE_ADS_ORCHESTRATOR_MODEL / GOOGLE_DEFAULT_MODEL)
GEMINI_KEY=

# -----------------------------------------------------------------------------
# Health / triage (Point-of-Care)
# -----------------------------------------------------------------------------

# Feature flag (set to "false" to disable /v1/health/analyze)
HEALTH_TRIAGE_ENABLED=true

# Internal sidecar services (Python containers/VMs)
MONAI_SERVICE_URL=
METABCI_SERVICE_URL=

# Optional self-hosted medical LLM endpoints (OpenAI-compatible /chat/completions)
HUATUOGPT_ENDPOINT=
HUATUOGPT_API_KEY=
HUATUOGPT_MODEL=

MEDGEMMA_ENDPOINT=
MEDGEMMA_API_KEY=
MEDGEMMA_MODEL=

# Optional: model id for Gemini text fallback when HuatuoGPT/MedGemma are unavailable (requires GEMINI_KEY).
# Defaults to GOOGLE_DEFAULT_MODEL / GOOGLE_CAMPAIGN_ORCHESTRATOR_MODEL, else gemini-2.0-flash. Use gemini-3.1-flash when your API exposes it.
HEALTH_GEMINI_MODEL=

# -----------------------------------------------------------------------------
# Neuro / BCI (Neural-Mobility & ALS Assist)
# -----------------------------------------------------------------------------

# Feature flag (set to "false" to disable POST /api/v1/neuro/decode)
NEURO_DECODE_ENABLED=true

# Uses GEMINI_KEY + METABCI_SERVICE_URL (same as health triage). No extra keys required.

# -----------------------------------------------------------------------------
# Cognitive wellness (mental wellness / focus / burnout-adjacent apps)
# -----------------------------------------------------------------------------

# Feature flag (set to "false" to disable POST /api/v1/health/wellness)
COGNITIVE_WELLNESS_ENABLED=true

# Same optional stack as triage: GEMINI_KEY (cognitive inference + synthesis fallback),
# METABCI_SERVICE_URL (EEG classify), HUATUOGPT_* (optional screenshot vision),
# MEDGEMMA_* (optional coach/clinical-style copy; falls back to Gemini).

# -----------------------------------------------------------------------------
# Health decision APIs (async jobs; GEMINI_KEY + optional MEDGEMMA_* / MONAI / Huatuo)
# -----------------------------------------------------------------------------

PATIENT_RISK_PRIORITY_ENABLED=true
ADHERENCE_DETECTION_ENABLED=true
NOTES_STRUCTURING_ENABLED=true
CLINICAL_DECISION_ENABLED=true
MEDICATION_CHECK_ENABLED=true
SCAN_ANALYSIS_ENABLED=true
RESEARCH_ASSIST_ENABLED=true

