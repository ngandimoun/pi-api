# -----------------------------------------------------------------------------
# Pi API — environment variable NAMES only (no secrets in repo).
# Values come from your secret store / deployment platform.
# -----------------------------------------------------------------------------

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Unkey (API keys + verification; rate limits / metering)
UNKEY_ROOT_KEY=
UNKEY_API_ID=

# Supabase (Postgres + Auth + pgvector)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (metered billing; tie to Unkey identity in application logic)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Trigger.dev (durable jobs / workers)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Firecrawl (web extraction / branding capture)
FIRECRAWL_API_KEY=
FIRECRAWL_ENABLE_SCREENSHOT=true
FIRECRAWL_ENABLE_ACTION_WAIT=false
FIRECRAWL_ACTION_WAIT_MS=0

# Model providers — use DB routing in production; these are bootstrap fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Optional: default model IDs (prefer DB config)
OPENAI_DEFAULT_MODEL=
ANTHROPIC_DEFAULT_MODEL=
GOOGLE_DEFAULT_MODEL=
DEEPSEEK_DEFAULT_MODEL=
GOOGLE_BRAND_VISION_MODEL=
GOOGLE_BRAND_STRUCTURING_MODEL=gemini-3.1-pro-preview
GOOGLE_BRAND_THINKING_LEVEL=medium
GOOGLE_BRAND_VISION_MAX_OUTPUT_TOKENS=1200
GOOGLE_BRAND_STRUCTURING_MAX_OUTPUT_TOKENS=700
GOOGLE_BRAND_PROJECTION_MODEL=gemini-2.5-flash-lite
GOOGLE_BRAND_PROJECTION_MAX_OUTPUT_TOKENS=180
GOOGLE_BRAND_PROJECTION_MAX_USE_CASE_CHARS=700
GOOGLE_BRAND_PROJECTION_MODEL_USE_CASE_CHARS=220
GOOGLE_BRAND_PROJECTION_MAX_DNA_CHARS=6000
GOOGLE_BRAND_PROJECTION_MAX_BODY_BYTES=8192
GOOGLE_BRAND_PROJECTION_ABUSE_WINDOW_MS=600000
GOOGLE_BRAND_PROJECTION_ABUSE_MAX_VIOLATIONS=3

# Scripts / golden checks (optional; see docs/v1/intro.mdx Deploy Checklist)
PI_BASE_URL=http://localhost:3000
PROJECTION_GOLDEN_BRAND_ID=
PROJECTION_GOLDEN_ORG_ID=
PROJECTION_GOLDEN_MAX_DETERMINISTIC_RATE=0
PROJECTION_GOLDEN_MAX_NON_LLM_RATE=
PROJECTION_GOLDEN_MAX_FALLBACK_RATE=
PROJECTION_GOLDEN_MAX_P95_MS=15000

# Cloudflare R2 (S3-compatible, zero egress on R2; keys only in env / secret store)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for objects (custom domain or r2.dev public bucket URL)
R2_PUBLIC_URL=
