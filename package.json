{
  "name": "pi-api",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:trigger:surveillance": "npx trigger.dev@latest dev --config trigger.surveillance.config.ts --env-file .env.local --log-level debug",
    "dev:trigger:robotics": "npx trigger.dev@latest dev --config trigger.robotics.config.ts --env-file .env.local --log-level debug",
    "build": "next build",
    "start": "next start",
    "predeploy": "npm run firecrawl:check",
    "lint": "eslint .",
    "test": "vitest run",
    "test:health-e2e": "node scripts/health-e2e-suite.mjs",
    "firecrawl:check": "node scripts/firecrawl-check.mjs",
    "projection:golden-check": "node scripts/projection-golden-check.mjs",
    "voice:e2e": "node scripts/voice-api-e2e.mjs",
    "skills:update": "node scripts/skills-update.mjs",
    "mastra:skills:update": "node scripts/mastra-skills-update.mjs",
    "sdk:build": "npm -w packages/pi-sdk run build",
    "sdk:ci": "npm -w packages/pi-sdk run ci",
    "cli:build": "npm -w packages/pi-cli run build",
    "cli:ci": "npm -w packages/pi-cli run ci",
    "hokage:build": "npm -w packages/pi-hokage run build",
    "test:cli-e2e": "node scripts/pi-cli-e2e.mjs",
    "verify:mastra-hokage": "node scripts/mastra-hokage-verify.mjs",
    "verify:mastra-schema": "node scripts/verify-mastra-schema.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@base-ui/react": "^1.3.0",
    "@google/genai": "^1.46.0",
    "@mastra/core": "^1.24.1",
    "@mastra/memory": "^1.15.0",
    "@mastra/pg": "^1.9.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@trigger.dev/sdk": "4.4.3",
    "@types/mime-types": "^3.0.1",
    "@unkey/api": "^2.3.2",
    "ai": "^6.0.134",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "image-size": "^2.0.2",
    "katex": "^0.16.44",
    "livekit-client": "^2.18.0",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.577.0",
    "mime-types": "^3.0.2",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "pi-routine-spec": "file:packages/pi-routine-spec",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.16.0",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.0",
    "stripe": "^18.0.0",
    "tailwind-merge": "^3.5.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "trigger.dev": "4.4.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
